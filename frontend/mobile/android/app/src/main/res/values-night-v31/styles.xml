<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark-mode counterpart of values-v31/styles.xml — see that file for why
         this override exists. Black splash background matches the app's OLED
         dark theme (kPanelDark family) instead of the light default. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
    </style>
</resources>
