<?xml version="1.0" encoding="utf-8"?>
<!-- Fixed-size wrapper around splash_logo.png (994x1429px raw). Referenced
     directly by a plain bitmap, the logo rendered at native pixel size on a
     baseline-density resource bucket and overflowed the splash area/icon box.
     Sizing it here (item width/height + fill) scales it down consistently
     wherever this drawable is used: launch_background (pre-API31) and
     windowSplashScreenAnimatedIcon (API31+ native splash). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="64dp"
        android:height="92dp"
        android:gravity="center">
        <bitmap
            android:src="@drawable/splash_logo"
            android:gravity="fill" />
    </item>
</layer-list>
